'use client';

import { useState } from 'react';
import { usePathname, useRouter } from 'next/navigation';
import { useAuth } from '@/context/AuthContext';
import { motion, Animatearesence } from 'framer-motion';
import { Home, CheckSquare, Users, MessageSquare, LogOut, GraduationCap, ChevronLeft, ChevronRight, User } from 'lucide-react';
import Link from 'next/link';
import { Avatar, AvatarFallback, AvatarImage } from '@/components/ui/avatar';

export default function Sidebar({ role }) {
  const pathname = usePathname();
  const router = useRouter();
  const { user, logout } = useAuth();
  const [isCollapsed, setIsCollapsed] = useState(false);
  const [isMenuOpen, setIsMenuOpen] = useState(false);

  const getNavigationLinks = () => {
    const baseLinks = [
      { path: `/${role.toLowerCase()}`, label: 'Dashboard', Icon: Home },
    ];

    if (role === 'STUDENT') {
      baseLinks.push({ path: '/student/todos', label: 'My Todos', Icon: CheckSquare });
      baseLinks.push({ path: '/student/exams', label: 'Exams', Icon: GraduationCap });
    }

    if (role === 'TEACHER') {
      baseLinks.push({ path: '/teacher/todos', label: 'My Todos', Icon: CheckSquare });
      baseLinks.push({ path: '/teacher/exams', label: 'Exams', Icon: GraduationCap });
    }

    if (role === 'ADMIN') {
      baseLinks.push({ path: '/admin/users', label: 'User Management', Icon: Users });
    }

    baseLinks.push({ path: `/${role.toLowerCase()}/messages`, label: 'Messages', Icon: MessageSquare });

    return baseLinks;
  };

  const links = getNavigationLinks();

  const handleLogout = () => {
    logout();
    router.push('/login');
  };

  return (
    <motion.aside 
      className="sticky top-0 h-screen glass-panel border-l-0 border-y-0 border-r border-white/10 flex flex-col pt-8 pb-6 bg-[#07090f]/80 flex-shrink-0"
      animate={{ 
        width: isCollapsed ? '80px' : '225px'
      }}
      transition={{ duration: 0.3, ease: 'easeInOut' }}
    >
      {/* Collapse Toggle Button */}
      <button
        onClick={() => setIsCollapsed(!isCollapsed)}
        className="absolute -right-3 top-8 w-6 h-6 rounded-full bg-violet-600 hover:bg-violet-500 flex items-center justify-center text-white shadow-lg z-50 transition-colors"
      >
        {isCollapsed ? <ChevronRight className="w-4 h-4" /> : <ChevronLeft className="w-4 h-4" />}
      </button>

      {/* Logo Area */}
      <div 
        className="flex items-center gap-3 mb-10 overflow-hidden"
        style={{
          transition: 'all 0.3s ease-in-out',
          paddingLeft: isCollapsed ? '20px' : '16px',
          paddingRight: isCollapsed ? '20px' : '16px'
        }}
      >
        <div className="w-10 h-10 rounded-xl bg-gradient-to-br from-violet-600 to-indigo-600 flex items-center justify-center shadow-lg shadow-violet-500/20 flex-shrink-0">
          <GraduationCap className="w-6 h-6 text-white" />
        </div>
        <div 
          className="overflow-hidden whitespace-nowrap"
          style={{
            transition: 'all 0.3s ease-in-out',
            opacity: isCollapsed ? 0 : 1,
            width: isCollapsed ? '0px' : 'auto'
          }}
        >
          <h2 className="text-xl font-bold font-heading text-white tracking-tight">CampusFlow</h2>
          <p className="text-[10px] uppercase font-bold tracking-widest text-violet-400">SSUET Portal</p>
        </div>
      </div>

      {/* Navigation */}
      <nav className="flex-1 space-y-1 px-2 overflow-y-auto">
        {links.map((link) => {
          const LinkIcon = link.Icon;
          const isActive = pathname === link.path;
          
          return (
            <Link key={link.path} href={link.path}>
              <div
                className={`relative flex items-center py-3 px-3 rounded-xl cursor-pointer group ${
                  isActive ? 'text-white' : 'text-slate-400 hover:text-white'
                }`}
                style={{
                  transition: 'all 0.3s ease-in-out'
                }}
                title={isCollapsed ? link.label : ''}
              >
                {isActive && (
                  <motion.div
                    layoutId="active-nav-bg"
                    className="absolute inset-0 bg-white/10 rounded-xl border border-white/5 shadow-[0_0_15px_rgba(167,139,250,0.1)]"
                    initial={false}
                    transition={{ type: "spring", bounce: 0.2, duration: 0.6 }}
                  />
                )}
                {isActive && !isCollapsed && (
                  <motion.div
                    className="absolute left-0 top-1/4 bottom-1/4 w-1 bg-violet-500 rounded-r-full shadow-[0_0_10px_rgba(167,139,250,0.8)]"
                    initial={false}
                  />
                )}
                
                <div className="flex items-center overflow-hidden w-full" style={{ 
                  transition: 'all 0.3s ease-in-out', 
                  transitionDelay: isCollapsed ? '0.2s' : '0s',
                  gap: isCollapsed ? '0px' : '12px', 
                  justifyContent: isCollapsed ? 'center' : 'flex-start'
                }}>
                  <span className={`relative z-10 p-1 rounded-lg transition-colors flex-shrink-0 ${isActive ? 'bg-violet-500/20 text-violet-300' : 'group-hover:bg-white/5'}`}>
                    <LinkIcon className="w-5 h-5" />
                  </span>
                  <span 
                    className="relative z-10 font-medium whitespace-nowrap overflow-hidden"
                    style={{
                      transition: 'all 0.3s ease-in-out',
                      opacity: isCollapsed ? 0 : 1,
                      width: isCollapsed ? '0px' : 'auto',
                      fontWeight: isActive ? 600 : 500
                    }}
                  >
                    {link.label}
                  </span>
                </div>
              </div>
            </Link>
          );
        })}
      </nav>

      {/* Divider */}
      <div className="w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent my-6" />

      {/* User Profile Footer with Expandable Card */}
      <div className="mt-auto px-2">
        <motion.div
          className="rounded-xl bg-black/20 border border-white/5 backdrop-blur-sm overflow-hidden cursor-pointer"
          animate={{ 
            height: isMenuOpen ? 'auto' : isCollapsed ? '58px' : '66px'
          }}
          transition={{ duration: 0.3, ease: 'easeInOut' }}
        >
          {/* Avatar Section - Always Visible */}
          <motion.button
            onClick={() => setIsMenuOpen(!isMenuOpen)}
            className="w-full p-3 hover:bg-white/5 transition-colors"
            animate={{ y: 0 }}
            transition={{ duration: 0.3 }}
          >
            <div className="flex items-center gap-3" style={{ justifyContent: isCollapsed ? 'center' : 'flex-start' }}>
              <Avatar className="w-10 h-10 border-2 border-white/10 shadow-lg flex-shrink-0">
                <AvatarImage src={user?.profile_picture_url} />
                <AvatarFallback className="bg-gradient-to-br from-violet-600 to-indigo-600 text-white font-heading">
                  {user?.first_name?.[0]}{user?.last_name?.[0]}
                </AvatarFallback>
              </Avatar>
              {!isCollapsed && (
                <div className="flex-1 min-w-0 text-left overflow-hidden" style={{ transition: 'all 0.3s ease-in-out', opacity: isCollapsed ? 0 : 1, width: isCollapsed ? '0px' : 'auto' }}>
                  <p className="text-sm font-bold text-white truncate font-heading">
                    {user?.first_name} {user?.last_name}
                  </p>
                  <p className="text-xs text-violet-400 font-medium truncate uppercase tracking-wider">
                    {role}
                  </p>
                </div>
              )}
            </div>
          </motion.button>

          {/* Expanded Menu Buttons */}
          <AnimatePresence>
            {isMenuOpen && (
              <motion.div
                initial={{ opacity: 0, height: 0 }}
                animate={{ opacity: 1, height: 'auto' }}
                exit={{ opacity: 0, height: 0 }}
                transition={{ duration: 0.3 }}
                className="border-t border-white/5"
              >
                <Link href={`/${role.toLowerCase()}/profile`}>
                  <motion.div
                    whileHover={{ backgroundColor: 'rgba(255, 255, 255, 0.05)' }}
                    className="flex items-center gap-3 px-4 py-3 text-slate-300 hover:text-white transition-colors cursor-pointer border-b border-white/5"
                    style={{ justifyContent: isCollapsed ? 'center' : 'flex-start' }}
                  >
                    <User className="w-4 h-4 flex-shrink-0" />
                    {!isCollapsed && <span className="text-sm font-medium">Edit Profile</span>}
                  </motion.div>
                </Link>
                <motion.div
                  whileHover={{ backgroundColor: 'rgba(239, 68, 68, 0.1)' }}
                  className="flex items-center gap-3 px-4 py-3 text-red-400 hover:text-red-300 transition-colors cursor-pointer"
                  onClick={handleLogout}
                  style={{ justifyContent: isCollapsed ? 'center' : 'flex-start' }}
                >
                  <LogOut className="w-4 h-4 flex-shrink-0" />
                  {!isCollapsed && <span className="text-sm font-medium">Logout</span>}
                </motion.div>
              </motion.div>
            )}
          </AnimatePresence>
        </motion.div>
      </div>
    </motion.aside>
  );
}
